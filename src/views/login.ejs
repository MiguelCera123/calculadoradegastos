<%- include('includes/head')%>
<%- include('includes/navbar')%>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-10">

      <div class="text-center mb-4">
        <h1 class="fw-bold" style="color:#539091;">Criar Conta ou Entrar</h1>
        <p class="lead text-muted">Acesse ou crie sua conta rapidamente</p>
      </div>
      <%- include('./includes/messages'); %>
      <div class="row g-4">
        
        <!-- Cadastro -->
        <div class="col-lg-6">
          <div class="card shadow border-0 h-100">
            <div class="card-body p-4">
              <h4 class="mb-3" style="color:#539091;">Cadastro</h4>
              <p class="text-muted">Ainda não tem conta? Crie abaixo:</p>

              <form class="form-cadastro" action="/login/register" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <div class="mb-3">
                  <label class="form-label">Email</label>
                  <input type="email" class="form-control" name="email">
                </div>

                <div class="mb-3">
                  <label class="form-label">Senha</label>
                  <input type="password" class="form-control" name="senha">
                </div>

                <button type="submit" class="btn w-100 text-white" style="background-color:#539091;">
                  Criar Conta
                </button>
              </form>
            </div>
          </div>
        </div>

        <!-- Login -->
        <div class="col-lg-6">
          <div class="card shadow border-0 h-100">
            <div class="card-body p-4">
              <h4 class="mb-3 text-black">Login</h4>
              <p class="text-black">Já possui conta? Entre abaixo:</p>

              <form class="form-login" action="/login/login" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <div class="mb-3">
                  <label class="form-label text-black">Email</label>
                  <input type="email" class="form-control" name="email">
                </div>

                <div class="mb-3">
                  <label class="form-label text-black">Senha</label>
                  <input type="password" class="form-control" name="senha">
                </div>

                <button type="submit" class="btn w-100 btn-light" style="background-color:#ecc0c0;"> 
                  Entrar
                </button>
              </form>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>
</div>
<%- include('includes/footer')%>